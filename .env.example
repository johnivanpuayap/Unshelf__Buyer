# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Get these from the Firebase Console for project `unshelf-d4567`:
#   https://console.firebase.google.com/project/unshelf-d4567/settings/general
# For each platform (Web, Android, iOS), there's a Firebase config snippet
# that shows the apiKey + appId. Use the WEB values for FIREBASE_WEB_*
# and the Android values for the bare FIREBASE_* keys (the bare ones also
# happen to work for iOS since iOS uses the same numerical sender/project).

# Firebase — Android / iOS native
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_PROJECT_ID=unshelf-d4567
FIREBASE_STORAGE_BUCKET=unshelf-d4567.appspot.com
FIREBASE_MESSAGING_SENDER_ID=733152787617

# Firebase — Web (Chrome / Edge / built web app)
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_APP_ID=

# Stripe — only required for payment flows; login + browsing work without it
stripePublishableKey=
stripeSecretKey=

# Google Sign-In — only required if you wire up Google OAuth sign-in
GOOGLE_CLIENT_ID=
